{
  "name": "siteclinic-web",
  "version": "0.1.0",
  "private": true,
  "description": "Site Clinic public marketing surface — siteclinic.io. Built through build-websites-template doctrine. Operations dashboard lives separately at app.siteclinic.io (site-monitor repo).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gate:ada": "gate-ada",
    "gate:seo": "gate-seo",
    "gate:all": "npm run gate:ada && npm run gate:seo",
    "prebuild": "npm run gate:all"
  },
  "dependencies": {
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "build-websites-tools": "file:./tools/build-websites-tools",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
